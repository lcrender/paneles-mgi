# SMTP (Dattaweb u otro proveedor). Copiá este archivo a .env y completá SMTP_PASS.
#
# Producción con Docker Compose:
# - El archivo .env debe estar en el MISMO directorio desde donde corrés `docker compose up`.
# - Compose inyecta ${VAR} en el contenedor; si falta .env, las variables llegan vacías.
# - Comprobación: GET https://tu-dominio/api/health → smtp.configured y missingEnvVars
# - O por SSH: docker exec paneles-mgi-web env | grep -E '^SMTP_|^CONTACT_'
# - Contraseñas con caracteres especiales: SMTP_PASS='tu@clave#compleja'

SMTP_HOST=vps-2949845-x.dattaweb.com
SMTP_PORT=465
SMTP_USER=paneles@mgzerosrl.com.ar
SMTP_PASS=

SMTP_FROM_NAME=Paneles MGI
SMTP_FROM_EMAIL=paneles@mgzerosrl.com.ar

CONTACT_TO_EMAIL=lucianogeuna@mgzerosrl.com.ar
CONTACT_BCC_EMAIL=lcrender@gmail.com
