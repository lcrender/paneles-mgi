# SMTP (Dattaweb u otro proveedor). Copiá este archivo a .env y completá SMTP_PASS.
#
# Si en logs ves algo como: 550 You can't login from <país>
# → El servidor SMTP (p. ej. Dattaweb) bloquea conexiones desde la IP de tu VPS cuando
#   esa IP figura en otro país (Hostinger y otros suelen usar rangos geolocalizados así).
#   No es un bug del sitio. Opciones: pedir a Dattaweb que permitan la IP del VPS;
#   usar el SMTP de Hostinger si tenés correo ahí; o un servicio transaccional
#   (Resend, Brevo, SendGrid) con API HTTPS en lugar de SMTP al servidor de Dattaweb.
#
# Producción con Docker Compose:
# - El archivo .env debe estar en el MISMO directorio desde donde corrés `docker compose up`.
# - Compose inyecta ${VAR} en el contenedor; si falta .env, las variables llegan vacías.
# - Comprobación: GET https://tu-dominio/api/health → smtp.configured y missingEnvVars
# - O por SSH: docker exec paneles-mgi-web env | grep -E '^SMTP_|^CONTACT_'
# - Contraseñas con caracteres especiales: SMTP_PASS='tu@clave#compleja'

SMTP_HOST=vps-2949845-x.dattaweb.com
# 465 = SSL implícito. En VPS (p. ej. Hostinger + Docker) suele funcionar mejor 587 + STARTTLS
SMTP_PORT=465
SMTP_USER=paneles@mgzerosrl.com.ar
SMTP_PASS=

# Si el certificado TLS es para otro hostname (p. ej. mail.tudominio.com), definí el nombre del certificado:
# SMTP_TLS_SERVERNAME=mail.tudominio.com

# Desactivar reintento automático 465↔587 (solo si necesitás un solo puerto)
# SMTP_NO_FALLBACK=true

# Solo si el servidor usa certificado no confiable (no recomendado en prod)
# SMTP_TLS_REJECT_UNAUTHORIZED=false

# Depuración SMTP en logs del contenedor (true/false)
# SMTP_DEBUG=true

SMTP_FROM_NAME=Paneles MGI
SMTP_FROM_EMAIL=paneles@mgzerosrl.com.ar

CONTACT_TO_EMAIL=lucianogeuna@mgzerosrl.com.ar
CONTACT_BCC_EMAIL=lcrender@gmail.com
